# ── Outputs ────────────────────────────────────────────────────────────────
# Path where generated images/videos are saved and served as static files.
OUTPUTS_DIR=../outputs

# ── Observability ──────────────────────────────────────────────────────────
# Append-only log file recording every pipeline phase for every job.
LOG_FILE=../activity.log

# ── Ollama (optional) ──────────────────────────────────────────────────────
# If Ollama is not running, the enhancer falls back to the raw transcript.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=minimax-m2.5:cloud

# ── Model selection ────────────────────────────────────────────────────────
# All models downloaded from HuggingFace Hub on first run. No API keys needed.
WHISPER_MODEL_SIZE=base
IMAGE_MODEL_ID=runwayml/stable-diffusion-v1-5
VIDEO_MODEL_ID=damo-vilab/text-to-video-ms-1.7b
